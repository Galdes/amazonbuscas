# Amazon Product Advertising API
# Obtenha em: https://affiliate-program.amazon.com/ (Programa de Associados)
AMAZON_ACCESS_KEY=sua_chave_de_acesso
AMAZON_SECRET_KEY=sua_chave_secreta
AMAZON_PARTNER_TAG=seu_id_de_associado-20
# Versão da API: 5 (padrão, JSON/Sig V4) ou 4 (XML/ItemSearch/Sig V2 - "API antiga")
AMAZON_PAAPI_VERSION=5
# Região da API (só usado na v5; ex: us-east-1 para EUA/Brasil)
AMAZON_REGION=us-east-1
# Host da API (ex: webservices.amazon.com.br para Brasil, webservices.amazon.com para EUA)
AMAZON_HOST=webservices.amazon.com.br

# Porta do servidor (opcional)
PORT=3001
